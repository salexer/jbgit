{
  "name": "vs-jb-git",
  "publisher": "salexer27",
  "displayName": "JBGit",
  "description": "JetBrains-like Git panel for VS Code and compatible IDEs.",
  "version": "0.2.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "jetbrains",
    "branches",
    "commits",
    "vscode",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/salexer/jbgit.git"
  },
  "homepage": "https://github.com/salexer/jbgit#readme",
  "bugs": {
    "url": "https://github.com/salexer/jbgit/issues"
  },
  "activationEvents": [
    "onView:jbGitBranches",
    "onView:jbGitCommits",
    "onView:jbGitChanges"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "jbGitPanel",
          "title": "JBGit",
          "icon": "media/jb-git.svg"
        }
      ]
    },
    "views": {
      "jbGitPanel": [
        {
          "id": "jbGitBranches",
          "name": "Branches",
          "type": "webview"
        },
        {
          "id": "jbGitCommits",
          "name": "Commits",
          "type": "webview"
        },
        {
          "id": "jbGitChanges",
          "name": "Changes",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vs-jb-git.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "vs-jb-git.focusPanel",
        "title": "JBGit: Focus JBGit"
      },
      {
        "command": "vs-jb-git.focusCommits",
        "title": "JBGit: Focus Commits"
      },
      {
        "command": "vs-jb-git.togglePrimaryFocus",
        "title": "JBGit: Toggle Primary Focus"
      },
      {
        "command": "vs-jb-git.refresh",
        "title": "Refresh"
      }
    ],
    "keybindings": [
      {
        "command": "vs-jb-git.togglePrimaryFocus",
        "key": "ctrl+alt+t",
        "mac": "alt+t",
        "when": "jbGit.focusedView == 'branches' || jbGit.focusedView == 'commits' || jbGit.focusedView == 'changes'"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vs-jb-git.refresh",
          "when": "view == jbGitBranches",
          "group": "navigation"
        },
        {
          "command": "vs-jb-git.refresh",
          "when": "view == jbGitCommits",
          "group": "navigation"
        },
        {
          "command": "vs-jb-git.refresh",
          "when": "view == jbGitChanges",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "JBGit",
      "properties": {
        "jbGit.updateMethod": {
          "type": "string",
          "enum": [
            "rebase",
            "merge"
          ],
          "default": "rebase",
          "description": "How the Update action synchronizes the current local branch with its upstream."
        },
        "jbGit.branchTaskUrl": {
          "type": "boolean",
          "default": false,
          "description": "Show a task link icon for local branches that are out of sync with their upstream."
        },
        "jbGit.branchTaskUrlTemplate": {
          "type": "string",
          "default": "",
          "description": "URL template for branch tasks. Use {BRANCH} as a placeholder, for example https://jira.my-url.ru/browse/{BRANCH}."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "package:vsix": "node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && npx --yes @vscode/vsce@3.9.2 package",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
